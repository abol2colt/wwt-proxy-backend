PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:4200

# Demo-safe Jira mock mode. Set to false only when real Jira env is configured.
ENABLE_INTEGRATION_MOCK_MODE=true

# Jira provider config
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_API_VERSION=3
JIRA_JQL=assignee=currentUser() AND statusCategory != Done ORDER BY updated DESC

# GitLab-compatible provider config
GITLAB_URL=http://127.0.0.1:8080
GITLAB_PROJECT_ID=replace-with-local-project-id
GITLAB_TOKEN=replace-with-local-token

# AI provider config
GEMINI_API_KEY=replace-with-local-key
GEMINI_MODEL=gemini-2.5-flash

# Optional network proxy for AI requests
USE_SOCKS_PROXY=false
SOCKS_PROXY_URL=socks5://127.0.0.1:1080
