PORT=3000
CORS_ORIGIN=http://localhost:4200

# GitLab-compatible provider config
GITLAB_URL=http://127.0.0.1:8080
GITLAB_TOKEN=replace-with-local-token
PROJECT_ID=replace-with-local-project-id

# AI provider config
GEMINI_API_KEY=replace-with-local-key
GEMINI_MODEL=gemini-1.5-flash

# Optional network proxy for AI requests
USE_SOCKS_PROXY=false
SOCKS_PROXY_URL=socks5://127.0.0.1:1080
